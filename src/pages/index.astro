---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch blog posts count for stats
const blogPosts = await getCollection('blog');

// Fetch work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

// Skills data
const skills = [
	{ name: 'React', icon: '⚛️', level: 95 },
	{ name: 'TypeScript', icon: '📘', level: 90 },
	{ name: 'Node.js', icon: '🟢', level: 85 },
	{ name: 'GraphQL', icon: '◈', level: 80 },
	{ name: 'AWS', icon: '☁️', level: 75 },
	{ name: 'Docker', icon: '🐳', level: 80 },
];

// Tech stack
const techStack = ['React', 'TypeScript', 'Node.js', 'GraphQL', 'PostgreSQL', 'AWS', 'Docker', 'Kubernetes'];

// Social links
const socials = [
	{ name: 'GitHub', url: 'https://github.com/cavr', icon: 'github' },
	{ name: 'LinkedIn', url: 'https://www.linkedin.com/in/carlos-aar%C3%B3n-villanueva-b2270a32/', icon: 'linkedin' },
	{ name: 'Twitter', url: 'https://twitter.com/CarlosAaronVill', icon: 'twitter' },
];
---

<BaseLayout>
	<!-- Navigation -->
	<nav class="nav">
		<div class="nav-container">
			<a href="#hero" class="nav-logo">
				<span class="logo-bracket">{</span>
				<span class="logo-text">CV</span>
				<span class="logo-bracket">}</span>
			</a>

			<button class="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
				<span class="hamburger"></span>
			</button>

			<ul class="nav-links">
				<li><a href="#about" class="nav-link">// about</a></li>
				<li><a href="#skills" class="nav-link">// skills</a></li>
				<li><a href="#work" class="nav-link">// work</a></li>
				<li><a href="#play" class="nav-link">// play</a></li>
				<li><a href="/personal-site/blog/" class="nav-link">// blog</a></li>
				<li><a href="#contact" class="nav-link">// contact</a></li>
			</ul>

			<div class="nav-socials">
				{socials.map(social => (
					<a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.name} class="social-link">
						{social.icon === 'github' && (
							<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
						)}
						{social.icon === 'linkedin' && (
							<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						)}
						{social.icon === 'twitter' && (
							<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						)}
					</a>
				))}
			</div>
		</div>
	</nav>

	<!-- Hero Section -->
	<section id="hero" class="hero">
		<div class="hero-content">
			<div class="terminal-window">
				<div class="terminal-header">
					<span class="terminal-dot red"></span>
					<span class="terminal-dot yellow"></span>
					<span class="terminal-dot green"></span>
					<span class="terminal-title">~/carlos-villanueva</span>
				</div>
				<div class="terminal-body">
					<p class="terminal-line">
						<span class="prompt">$</span>
						<span class="command tw-cmd-1"></span><span class="tw-cursor">▋</span>
					</p>
					<p class="terminal-output hero-greeting tw-out-1" style="opacity:0">Hello, I'm</p>
					<h1 class="hero-name tw-out-1" style="opacity:0">
						<span class="gradient-text">Carlos Villanueva</span>
					</h1>
					<p class="terminal-line tw-out-1" style="opacity:0">
						<span class="prompt">$</span>
						<span class="command tw-cmd-2"></span><span class="tw-cursor">▋</span>
					</p>
					<p class="hero-title tw-out-2" style="opacity:0">Senior Software Engineer</p>
					<p class="terminal-line tw-out-2" style="opacity:0">
						<span class="prompt">$</span>
						<span class="command tw-cmd-3"></span><span class="tw-cursor">▋</span>
					</p>
					<div class="tech-tags tw-out-3" style="opacity:0">
						{techStack.map(tech => (
							<span class="tech-tag">{tech}</span>
						))}
					</div>
				</div>
			</div>

			<div class="hero-cta">
				<a href="#work" class="btn btn-primary">
					<span>View My Work</span>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
				</a>
				<a href="#contact" class="btn">
					<span>Get In Touch</span>
				</a>
			</div>
		</div>

		<div class="scroll-indicator">
			<span>Scroll</span>
			<div class="scroll-line"></div>
		</div>
	</section>

	<!-- About Section -->
	<section id="about" class="section about">
		<div class="container">
			<header class="section-header">
				<span class="section-number">01</span>
				<h2>// About Me</h2>
			</header>

			<div class="about-content">
				<div class="about-text">
					<p class="about-intro">
						I'm a <span class="highlight">Senior Software Engineer</span> with over 12 years of experience building scalable web applications and leading engineering teams.
					</p>
					<p>
						Currently focused on creating exceptional digital experiences using modern technologies. I specialize in React, TypeScript, and Node.js, with a passion for clean code, performance optimization, and developer experience.
					</p>
					<p>
						When I'm not coding, you'll find me exploring new technologies, contributing to open source, or enjoying time with family and friends.
					</p>

					<div class="about-stats">
						<div class="stat">
							<span class="stat-number">12+</span>
							<span class="stat-label">Years Experience</span>
						</div>
						<div class="stat">
							<span class="stat-number">8</span>
							<span class="stat-label">Companies</span>
						</div>
						<div class="stat">
							<span class="stat-number">{blogPosts.length}</span>
							<span class="stat-label">Blog Posts</span>
						</div>
					</div>
				</div>

				<div class="about-image">
					<div class="image-frame">
						<img
							src="/personal-site/assets/portrait.jpg"
							alt="Carlos Villanueva"
							width="400"
							height="500"
							loading="lazy"
						/>
						<div class="image-border"></div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Skills Section -->
	<section id="skills" class="section skills">
		<div class="container">
			<header class="section-header">
				<span class="section-number">02</span>
				<h2>// Skills & Expertise</h2>
			</header>

			<div class="skills-grid stagger">
				<div class="skill-card card">
					<div class="skill-icon">
						<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 6.1H3M21 12H3M21 18H3"/><circle cx="19" cy="6" r="2"/></svg>
					</div>
					<h3>Frontend Development</h3>
					<p>Building modern, responsive interfaces with React, TypeScript, and Next.js. Expert in state management, component architecture, and performance optimization.</p>
					<div class="skill-tags">
						<span>React</span>
						<span>TypeScript</span>
						<span>Next.js</span>
					</div>
				</div>

				<div class="skill-card card">
					<div class="skill-icon">
						<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
					</div>
					<h3>Backend Development</h3>
					<p>Creating robust APIs and microservices with Node.js, Express, and GraphQL. Experienced with databases, caching, and message queues.</p>
					<div class="skill-tags">
						<span>Node.js</span>
						<span>GraphQL</span>
						<span>PostgreSQL</span>
					</div>
				</div>

				<div class="skill-card card">
					<div class="skill-icon">
						<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
					</div>
					<h3>DevOps & Cloud</h3>
					<p>Setting up CI/CD pipelines, containerization with Docker, and cloud infrastructure on AWS. Familiar with Kubernetes and infrastructure as code.</p>
					<div class="skill-tags">
						<span>AWS</span>
						<span>Docker</span>
						<span>Kubernetes</span>
					</div>
				</div>

				<div class="skill-card card">
					<div class="skill-icon">
						<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
					</div>
					<h3>Team Leadership</h3>
					<p>Leading and mentoring development teams, conducting code reviews, and establishing best practices. Strong communication and collaboration skills.</p>
					<div class="skill-tags">
						<span>Agile</span>
						<span>Mentoring</span>
						<span>Code Review</span>
					</div>
				</div>
			</div>

			<div class="skills-bar-section">
				<h3>// Stack</h3>
				<p class="stack-subtitle">Problem solver first, tool picker second. Pragmatic by nature — no reinventing the wheel.</p>
				<div class="skills-pills">
					{skills.map(skill => (
						<span class="skill-pill">
							<span class="skill-bar-icon">{skill.icon}</span>
							<span class="skill-bar-name">{skill.name}</span>
						</span>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- Work Section -->
	<section id="work" class="section work">
		<div class="container">
			<header class="section-header">
				<span class="section-number">03</span>
				<h2>// Selected Work</h2>
			</header>

			<div class="work-grid stagger">
				{projects.map((project, index) => (
					<a href={`/personal-site/work/${project.slug}`} class="work-card">
						<div class="work-card-image">
							<img
								src={project.data.img}
								alt={project.data.img_alt || project.data.title}
								loading="lazy"
							/>
							<div class="work-card-overlay">
								<span class="view-project">View Project</span>
							</div>
						</div>
						<div class="work-card-content">
							<span class="work-card-number">{String(index + 1).padStart(2, '0')}</span>
							<h3>{project.data.title}</h3>
							<p>{project.data.description}</p>
							<div class="work-card-tags">
								{project.data.tags.slice(0, 3).map(tag => (
									<span class="work-tag">{tag}</span>
								))}
							</div>
						</div>
					</a>
				))}
			</div>

			<div class="work-cta">
				<a href="/personal-site/work/" class="btn">
					<span>View All Projects</span>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</a>
			</div>
		</div>
	</section>

	<!-- Play Section -->
	<section id="play" class="section play-section">
		<div class="container">
			<header class="section-header">
				<span class="section-number">04</span>
				<h2>// Play</h2>
				<p class="section-description">Not everything has to be professional.</p>
			</header>
			<div class="play-grid">
				<a href="/personal-site/play" class="play-card">
					<div class="play-card-screen">
						<div class="play-scanlines" aria-hidden="true"></div>
						<div class="play-card-content">
							<span class="play-card-badge">NES Emulator</span>
							<h3 class="play-card-title">Nomolos</h3>
							<p class="play-card-sub">+ load your own ROMs</p>
						</div>
						<div class="play-card-cta">
							<span class="play-card-btn">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
								Press Start
							</span>
						</div>
					</div>
					<div class="play-card-info">
						<p>A fully client-side NES emulator running in the browser. Comes loaded with a free homebrew platformer, or drop in any <code>.nes</code> file you own.</p>
						<span class="play-card-link">
							Open emulator
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</span>
					</div>
				</a>

				<a href="/personal-site/play/matrix" class="play-card play-card--matrix">
					<div class="play-card-screen matrix-screen">
						<canvas class="matrix-preview-canvas" aria-hidden="true"></canvas>
						<div class="play-card-content">
							<span class="play-card-badge">Canvas Demo</span>
							<h3 class="play-card-title">Matrix</h3>
							<p class="play-card-sub">digital rain</p>
						</div>
						<div class="play-card-cta">
							<span class="play-card-btn">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
								Enter
							</span>
						</div>
					</div>
					<div class="play-card-info">
						<p>A full-screen Matrix digital rain canvas animation. Fully interactive — click to change speed, colour, and density.</p>
						<span class="play-card-link">
							Open demo
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</span>
					</div>
				</a>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="section contact">
		<div class="container">
			<header class="section-header">
				<span class="section-number">05</span>
				<h2>// Get In Touch</h2>
			</header>

			<div class="contact-content">
				<div class="contact-text">
					<p class="contact-intro">
						I'm always interested in hearing about new projects and opportunities. Whether you have a question or just want to say hi, feel free to reach out!
					</p>

					<div class="contact-terminal">
						<div class="terminal-window small">
							<div class="terminal-header">
								<span class="terminal-dot red"></span>
								<span class="terminal-dot yellow"></span>
								<span class="terminal-dot green"></span>
							</div>
							<div class="terminal-body">
								<p class="terminal-line">
									<span class="prompt">$</span>
									<span class="command">echo $EMAIL</span>
								</p>
								<a href="mailto:carlos.aaron.villanueva@gmail.com" class="contact-email">carlos.aaron.villanueva@gmail.com</a>
							</div>
						</div>
					</div>
				</div>

				<div class="contact-links">
					<a href="mailto:carlos.aaron.villanueva@gmail.com" class="contact-link-card card">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
						<span>Send Email</span>
					</a>
					<a href="https://www.linkedin.com/in/carlos-aar%C3%B3n-villanueva-b2270a32/" target="_blank" rel="noopener noreferrer" class="contact-link-card card">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						<span>LinkedIn</span>
					</a>
					<a href="https://github.com/cavr" target="_blank" rel="noopener noreferrer" class="contact-link-card card">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
						<span>GitHub</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<footer class="footer">
		<div class="container">
			<div class="footer-content">
				<p class="footer-text">
					<span class="terminal-text">Designed & Built by Carlos Villanueva</span>
				</p>
				<div class="footer-right">
					<a href="/personal-site/play" class="footer-recruiter-link">
						Play NES
					</a>
					<p class="footer-copyright">
						&copy; {new Date().getFullYear()} All rights reserved.
					</p>
				</div>
			</div>
		</div>
	</footer>
</BaseLayout>

<style>
	/* ========================================
	   Navigation
	   ======================================== */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: var(--z-nav);
		background: rgba(10, 10, 15, 0.9);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border-color);
	}

	:global([data-theme="light"]) .nav {
		background: rgba(247, 247, 249, 0.92);
	}

	.nav-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1400px;
		margin: 0 auto;
		padding: var(--space-4) var(--space-6);
	}

	.nav-logo {
		font-family: var(--font-mono);
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--text-primary);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.logo-bracket {
		color: var(--accent-primary);
	}

	.logo-text {
		color: var(--text-primary);
	}

	.nav-links {
		display: none;
		list-style: none;
		gap: var(--space-8);
	}

	.nav-links.active {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		position: absolute;
		top: 100%;
		left: 0;
		right: 0;
		background: rgba(10, 10, 15, 0.97);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border-color);
		padding: var(--space-4) var(--space-6);
	}

	:global([data-theme="light"]) .nav-links.active {
		background: rgba(247, 247, 249, 0.97);
	}

	.nav-link {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.nav-link:hover {
		color: var(--accent-primary);
	}

	.nav-socials {
		display: none;
		gap: var(--space-4);
	}

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		color: var(--text-secondary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-sm);
		transition: all var(--transition-fast);
	}

	.social-link svg {
		width: 18px;
		height: 18px;
	}

	.social-link:hover {
		color: var(--accent-primary);
		border-color: var(--accent-primary);
		box-shadow: var(--glow-primary);
	}

	.mobile-menu-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		background: transparent;
		border: 1px solid var(--border-color);
		border-radius: var(--radius-sm);
		cursor: pointer;
	}

	.hamburger {
		position: relative;
		width: 20px;
		height: 2px;
		background: var(--text-primary);
	}

	.hamburger::before,
	.hamburger::after {
		content: '';
		position: absolute;
		width: 100%;
		height: 100%;
		background: var(--text-primary);
		left: 0;
	}

	.hamburger::before { top: -6px; }
	.hamburger::after { top: 6px; }

	@media (min-width: 768px) {
		.nav-links {
			display: flex;
		}

		.nav-socials {
			display: flex;
		}

		.mobile-menu-btn {
			display: none;
		}
	}

	/* ========================================
	   Hero Section
	   ======================================== */
	.hero {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		padding: var(--space-24) var(--space-6);
		position: relative;
	}

	.hero-content {
		max-width: 900px;
		width: 100%;
	}

	.terminal-window {
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-lg);
		overflow: hidden;
		animation: fade-in-up 0.8s ease-out;
	}

	/* Typewriter elements */
	.tw-out-1,
	.tw-out-2,
	.tw-out-3 {
		transition: opacity 0.3s ease;
	}

	.tw-cursor {
		display: inline-block;
		color: var(--accent-primary);
		font-family: var(--font-mono);
		animation: blink-caret 1s step-end infinite;
		font-size: var(--text-sm);
		vertical-align: middle;
	}

	.terminal-window.small {
		max-width: 500px;
	}

	.terminal-header {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-3) var(--space-4);
		background: var(--bg-tertiary);
		border-bottom: 1px solid var(--border-color);
	}

	.terminal-dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
	}

	.terminal-dot.red { background: #ff5f56; }
	.terminal-dot.yellow { background: #ffbd2e; }
	.terminal-dot.green { background: #27c93f; }

	.terminal-title {
		margin-left: var(--space-4);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-muted);
	}

	.terminal-body {
		padding: var(--space-6);
	}

	.terminal-line {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin-bottom: var(--space-2);
	}

	.prompt {
		color: var(--accent-primary);
		margin-right: var(--space-2);
	}

	.command {
		color: var(--accent-secondary);
	}

	.terminal-output {
		color: var(--text-secondary);
	}

	.hero-greeting {
		font-size: var(--text-lg);
		color: var(--text-secondary);
		margin-top: var(--space-4);
	}

	.hero-name {
		font-size: clamp(2.5rem, 8vw, 5rem);
		line-height: 1.1;
		margin: var(--space-2) 0 var(--space-6);
	}

	.hero-title {
		font-family: var(--font-mono);
		font-size: var(--text-xl);
		color: var(--accent-primary);
		margin-bottom: var(--space-6);
	}

	.tech-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-top: var(--space-2);
	}

	.tech-tag {
		padding: var(--space-1) var(--space-3);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-secondary);
		background: var(--bg-tertiary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-sm);
	}

	.hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		margin-top: var(--space-8);
		animation: fade-in-up 0.8s ease-out 0.3s both;
	}

	.scroll-indicator {
		position: absolute;
		bottom: var(--space-8);
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-2);
		color: var(--text-muted);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		animation: fade-in 1s ease-out 1s both;
	}

	.scroll-line {
		width: 1px;
		height: 60px;
		background: linear-gradient(to bottom, var(--accent-primary), transparent);
		animation: scroll-pulse 2s ease-in-out infinite;
	}

	@keyframes scroll-pulse {
		0%, 100% { opacity: 0.3; transform: scaleY(1); }
		50% { opacity: 1; transform: scaleY(1.2); }
	}

	/* ========================================
	   Section Headers
	   ======================================== */
	.section-header {
		margin-bottom: var(--space-12);
	}

	.section-number {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent-primary);
		margin-bottom: var(--space-2);
	}

	.section-header h2 {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
	}

	/* ========================================
	   About Section
	   ======================================== */
	.about-content {
		display: grid;
		gap: var(--space-12);
	}

	.about-intro {
		font-size: var(--text-xl);
		line-height: 1.6;
		margin-bottom: var(--space-6);
	}

	.highlight {
		color: var(--accent-primary);
	}

	.about-text p {
		margin-bottom: var(--space-4);
	}

	.about-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-6);
		margin-top: var(--space-8);
		padding-top: var(--space-8);
		border-top: 1px solid var(--border-color);
	}

	.stat {
		text-align: center;
	}

	.stat-number {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--text-3xl);
		font-weight: 700;
		color: var(--accent-primary);
	}

	.stat-label {
		font-size: var(--text-sm);
		color: var(--text-muted);
	}

	.about-image {
		display: flex;
		justify-content: center;
	}

	.image-frame {
		position: relative;
		max-width: 350px;
	}

	.image-frame img {
		width: 100%;
		height: auto;
		border-radius: var(--radius-lg);
		filter: grayscale(20%);
		transition: filter var(--transition-base);
	}

	.image-frame:hover img {
		filter: grayscale(0%);
	}

	.image-border {
		position: absolute;
		inset: 20px -20px -20px 20px;
		border: 2px solid var(--accent-primary);
		border-radius: var(--radius-lg);
		z-index: -1;
	}

	@media (min-width: 768px) {
		.about-content {
			grid-template-columns: 1.5fr 1fr;
			align-items: center;
		}
	}

	/* ========================================
	   Skills Section
	   ======================================== */
	.skills-grid {
		display: grid;
		gap: var(--space-6);
	}

	.skill-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	.skill-icon {
		width: 60px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		color: var(--accent-primary);
	}

	.skill-card h3 {
		font-size: var(--text-xl);
	}

	.skill-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-top: auto;
	}

	.skill-tags span {
		padding: var(--space-1) var(--space-3);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent-secondary);
		background: rgba(0, 212, 255, 0.1);
		border: 1px solid rgba(0, 212, 255, 0.3);
		border-radius: var(--radius-sm);
	}

	.skills-bar-section {
		margin-top: var(--space-16);
	}

	.skills-bar-section h3 {
		font-size: var(--text-xl);
		margin-bottom: var(--space-8);
	}

	.stack-subtitle {
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin: calc(-1 * var(--space-2)) 0 var(--space-6);
		font-style: italic;
	}

	.skills-pills {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	.skill-pill {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-2) var(--space-4);
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 9999px;
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-primary);
		transition: border-color var(--transition-fast), color var(--transition-fast);
	}

	.skill-pill:hover {
		border-color: var(--accent-primary);
		color: var(--accent-primary);
	}

	.skill-bar-icon {
		font-size: var(--text-base);
	}

	.skill-bar-name {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
	}

	@media (min-width: 768px) {
		.skills-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* ========================================
	   Work Section
	   ======================================== */
	.work-grid {
		display: grid;
		gap: var(--space-8);
	}

	.work-card {
		display: flex;
		flex-direction: column;
		background: var(--gradient-card);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-lg);
		overflow: hidden;
		text-decoration: none;
		transition: all var(--transition-base);
	}

	.work-card:hover {
		border-color: var(--accent-primary);
		box-shadow: var(--glow-primary);
		transform: translateY(-8px);
	}

	.work-card-image {
		position: relative;
		aspect-ratio: 16/10;
		overflow: hidden;
	}

	.work-card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform var(--transition-slow);
	}

	.work-card:hover .work-card-image img {
		transform: scale(1.05);
	}

	.work-card-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0, 255, 136, 0.1);
		opacity: 0;
		transition: opacity var(--transition-base);
	}

	.work-card:hover .work-card-overlay {
		opacity: 1;
	}

	.view-project {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent-primary);
		padding: var(--space-2) var(--space-4);
		background: var(--bg-primary);
		border: 1px solid var(--accent-primary);
		border-radius: var(--radius-sm);
	}

	.work-card-content {
		padding: var(--space-6);
	}

	.work-card-number {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent-primary);
	}

	.work-card-content h3 {
		font-size: var(--text-xl);
		margin: var(--space-2) 0 var(--space-3);
		color: var(--text-primary);
	}

	.work-card-content p {
		font-size: var(--text-sm);
		margin-bottom: var(--space-4);
	}

	.work-card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.work-tag {
		padding: var(--space-1) var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
		background: var(--bg-secondary);
		border-radius: var(--radius-sm);
	}

	.work-cta {
		display: flex;
		justify-content: center;
		margin-top: var(--space-12);
	}

	@media (min-width: 768px) {
		.work-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* ========================================
	   Play Section
	   ======================================== */
	.play-grid {
		display: grid;
		gap: var(--space-6);
	}

	@media (min-width: 900px) {
		.play-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.play-card {
		display: grid;
		grid-template-columns: 1fr;
		text-decoration: none;
		border: 1px solid var(--border-color);
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition: all var(--transition-base);
		background: var(--gradient-card);
	}

	.play-card:hover {
		border-color: var(--accent-primary);
		box-shadow: var(--glow-primary);
		transform: translateY(-4px);
	}

	.play-card-screen {
		position: relative;
		aspect-ratio: 16 / 7;
		background: #000;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--space-3);
		border-bottom: 1px solid var(--border-color);
		overflow: hidden;
	}

	/* animated grid background inside the screen */
	.play-card-screen::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(0, 255, 136, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(0, 255, 136, 0.04) 1px, transparent 1px);
		background-size: 32px 32px;
	}

	.play-scanlines {
		position: absolute;
		inset: 0;
		background: repeating-linear-gradient(
			to bottom,
			transparent,
			transparent 2px,
			rgba(0, 0, 0, 0.18) 2px,
			rgba(0, 0, 0, 0.18) 4px
		);
		pointer-events: none;
		z-index: 2;
	}

	.play-card-content {
		position: relative;
		z-index: 3;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-2);
		text-align: center;
	}

	.play-card-badge {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent-primary);
		background: rgba(0, 255, 136, 0.1);
		border: 1px solid rgba(0, 255, 136, 0.25);
		padding: 2px var(--space-3);
		border-radius: 9999px;
		letter-spacing: 0.08em;
	}

	.play-card-title {
		font-family: var(--font-mono);
		font-size: clamp(2rem, 6vw, 3.5rem);
		font-weight: 700;
		color: var(--accent-primary);
		text-shadow: 0 0 40px rgba(0, 255, 136, 0.6);
		margin: 0;
		animation: glow-pulse 2.5s ease-in-out infinite;
	}

	@keyframes glow-pulse {
		0%, 100% { text-shadow: 0 0 30px rgba(0, 255, 136, 0.5); }
		50%       { text-shadow: 0 0 70px rgba(0, 255, 136, 1); }
	}

	.play-card-sub {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
		margin: 0;
	}

	.play-card-cta {
		position: relative;
		z-index: 3;
	}

	.play-card-btn {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--bg-primary);
		background: var(--accent-primary);
		padding: var(--space-2) var(--space-5);
		border-radius: var(--radius-md);
		font-weight: 600;
		animation: btn-blink 1.8s step-end infinite;
	}

	@keyframes btn-blink {
		0%, 80%, 100% { opacity: 1; }
		85%            { opacity: 0; }
	}

	.play-card-info {
		padding: var(--space-6);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-6);
		flex-wrap: wrap;
	}

	.play-card-info p {
		font-size: var(--text-sm);
		color: var(--text-secondary);
		line-height: 1.6;
		margin: 0;
		max-width: 560px;
	}

	.play-card-info code {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent-secondary);
		background: rgba(0, 212, 255, 0.08);
		padding: 1px 5px;
		border-radius: var(--radius-sm);
	}

	.play-card-link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent-primary);
		white-space: nowrap;
		flex-shrink: 0;
	}

	.matrix-screen {
		position: relative;
		overflow: hidden;
	}

	.matrix-preview-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		opacity: 0.6;
	}

	/* ========================================
	   Contact Section
	   ======================================== */
	.contact {
		background: var(--bg-secondary);
	}

	.contact-content {
		display: grid;
		gap: var(--space-12);
	}

	.contact-intro {
		font-size: var(--text-lg);
		max-width: 600px;
		margin-bottom: var(--space-8);
	}

	.contact-terminal {
		margin-top: var(--space-6);
	}

	.contact-email {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--text-lg);
		color: var(--accent-primary);
		margin-top: var(--space-2);
		transition: color var(--transition-fast);
	}

	.contact-email:hover {
		color: var(--accent-secondary);
	}

	.contact-links {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
		gap: var(--space-4);
	}

	.contact-link-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-3);
		padding: var(--space-6);
		text-decoration: none;
		color: var(--text-secondary);
	}

	.contact-link-card svg {
		color: var(--accent-primary);
	}

	.contact-link-card span {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
	}

	.contact-link-card:hover {
		color: var(--accent-primary);
	}

	@media (min-width: 768px) {
		.contact-content {
			grid-template-columns: 1fr 1fr;
			align-items: start;
		}
	}

	/* ========================================
	   Footer
	   ======================================== */
	.footer {
		padding: var(--space-8) var(--space-6);
		border-top: 1px solid var(--border-color);
	}

	.footer-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-2);
		text-align: center;
	}

	.footer-text {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
	}

	.footer-right {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-1);
	}

	.footer-copyright {
		font-size: var(--text-xs);
		color: var(--text-muted);
	}

	.footer-recruiter-link {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
		text-decoration: none;
		border-bottom: 1px dashed var(--border-color);
		transition: color var(--transition-fast), border-color var(--transition-fast);
	}

	.footer-recruiter-link:hover {
		color: var(--accent-primary);
		border-color: var(--accent-primary);
	}

	@media (min-width: 768px) {
		.footer-content {
			flex-direction: row;
			justify-content: space-between;
		}

		.footer-right {
			align-items: flex-end;
		}
	}
</style>

<script>
	// Mobile menu toggle
	const menuBtn = document.querySelector('.mobile-menu-btn');
	const navLinks = document.querySelector('.nav-links');

	menuBtn?.addEventListener('click', () => {
		const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
		menuBtn.setAttribute('aria-expanded', String(!expanded));
		navLinks?.classList.toggle('active');
	});

	// Close menu when a nav link is clicked
	navLinks?.querySelectorAll('.nav-link').forEach(link => {
		link.addEventListener('click', () => {
			navLinks.classList.remove('active');
			menuBtn?.setAttribute('aria-expanded', 'false');
		});
	});

	// Active nav link on scroll
	const sections = document.querySelectorAll('section[id]');
	const navItems = document.querySelectorAll('.nav-link');

	const observerOptions = {
		threshold: 0.3,
		rootMargin: '-80px 0px -50% 0px'
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				navItems.forEach(link => {
					link.classList.remove('active');
					if (link.getAttribute('href') === `#${entry.target.id}`) {
						link.classList.add('active');
					}
				});
			}
		});
	}, observerOptions);

	sections.forEach(section => observer.observe(section));

	// Typewriter animation for hero terminal
	function typeWriter(el: HTMLElement, text: string, speed = 60): Promise<void> {
		return new Promise(resolve => {
			el.textContent = '';
			let i = 0;
			const tick = () => {
				if (i < text.length) {
					el.textContent += text[i++];
					setTimeout(tick, speed + Math.random() * 30);
				} else {
					resolve();
				}
			};
			tick();
		});
	}

	function revealAll(cls: string) {
		document.querySelectorAll<HTMLElement>(`.${cls}`).forEach(el => { el.style.opacity = '1'; });
	}

	async function runTerminalSequence() {
		const steps = [
			{ cmdEl: document.querySelector<HTMLElement>('.tw-cmd-1'), revealCls: 'tw-out-1', cmd: 'whoami', delay: 500 },
			{ cmdEl: document.querySelector<HTMLElement>('.tw-cmd-2'), revealCls: 'tw-out-2', cmd: 'cat role.txt', delay: 400 },
			{ cmdEl: document.querySelector<HTMLElement>('.tw-cmd-3'), revealCls: 'tw-out-3', cmd: 'echo $STACK', delay: 400 },
		];

		for (const step of steps) {
			if (!step.cmdEl) continue;
			await new Promise(r => setTimeout(r, step.delay));
			await typeWriter(step.cmdEl, step.cmd, 55);
			await new Promise(r => setTimeout(r, 200));
			revealAll(step.revealCls);
		}
	}

	runTerminalSequence();

	// Matrix preview canvas on the play card
	const matrixCanvas = document.querySelector<HTMLCanvasElement>('.matrix-preview-canvas');
	if (matrixCanvas) {
		const mc = matrixCanvas as HTMLCanvasElement;
		const ctx = mc.getContext('2d')!;
		const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン01';
		let cols: number[] = [];

		const resizeMc = () => {
			mc.width = mc.offsetWidth;
			mc.height = mc.offsetHeight;
			const count = Math.floor(mc.width / 14);
			cols = Array.from({ length: count }, () => Math.floor(Math.random() * mc.height / 14));
		};

		resizeMc();
		new ResizeObserver(resizeMc).observe(mc);

		setInterval(() => {
			ctx.fillStyle = 'rgba(0,0,0,0.1)';
			ctx.fillRect(0, 0, mc.width, mc.height);
			ctx.fillStyle = '#00ff88';
			ctx.font = '13px JetBrains Mono, monospace';
			cols.forEach((y, i) => {
				const char = chars[Math.floor(Math.random() * chars.length)];
				ctx.fillText(char, i * 14, y * 14);
				if (y * 14 > mc.height && Math.random() > 0.975) cols[i] = 0;
				else cols[i]++;
			});
		}, 60);
	}
</script>
