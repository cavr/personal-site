---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

// Skills data
const skills = [
	{ name: 'React', icon: '⚛️', level: 95 },
	{ name: 'TypeScript', icon: '📘', level: 90 },
	{ name: 'Node.js', icon: '🟢', level: 85 },
	{ name: 'GraphQL', icon: '◈', level: 80 },
	{ name: 'AWS', icon: '☁️', level: 75 },
	{ name: 'Docker', icon: '🐳', level: 80 },
];

// Tech stack
const techStack = ['React', 'TypeScript', 'Node.js', 'GraphQL', 'PostgreSQL', 'AWS', 'Docker', 'Kubernetes'];

// Social links
const socials = [
	{ name: 'GitHub', url: 'https://github.com/cavr', icon: 'github' },
	{ name: 'LinkedIn', url: 'https://www.linkedin.com/in/carlos-aar%C3%B3n-villanueva-b2270a32/', icon: 'linkedin' },
	{ name: 'Twitter', url: 'https://twitter.com/CarlosAaronVill', icon: 'twitter' },
];
---

<BaseLayout>
	<!-- Navigation -->
	<nav class="nav">
		<div class="nav-container">
			<a href="#hero" class="nav-logo">
				<span class="logo-bracket">{</span>
				<span class="logo-text">CV</span>
				<span class="logo-bracket">}</span>
			</a>

			<button class="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
				<span class="hamburger"></span>
			</button>

			<ul class="nav-links">
				<li><a href="#about" class="nav-link">// about</a></li>
				<li><a href="#skills" class="nav-link">// skills</a></li>
				<li><a href="#work" class="nav-link">// work</a></li>
				<li><a href="#contact" class="nav-link">// contact</a></li>
			</ul>

			<div class="nav-socials">
				{socials.map(social => (
					<a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.name} class="social-link">
						{social.icon === 'github' && (
							<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
						)}
						{social.icon === 'linkedin' && (
							<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						)}
						{social.icon === 'twitter' && (
							<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						)}
					</a>
				))}
			</div>
		</div>
	</nav>

	<!-- Hero Section -->
	<section id="hero" class="hero">
		<div class="hero-content">
			<div class="terminal-window">
				<div class="terminal-header">
					<span class="terminal-dot red"></span>
					<span class="terminal-dot yellow"></span>
					<span class="terminal-dot green"></span>
					<span class="terminal-title">~/carlos-villanueva</span>
				</div>
				<div class="terminal-body">
					<p class="terminal-line">
						<span class="prompt">$</span>
						<span class="command">whoami</span>
					</p>
					<p class="terminal-output hero-greeting">Hello, I'm</p>
					<h1 class="hero-name">
						<span class="gradient-text">Carlos Villanueva</span>
					</h1>
					<p class="terminal-line">
						<span class="prompt">$</span>
						<span class="command">cat role.txt</span>
					</p>
					<p class="hero-title">Senior Software Engineer</p>
					<p class="terminal-line">
						<span class="prompt">$</span>
						<span class="command">echo $STACK</span>
					</p>
					<div class="tech-tags">
						{techStack.map(tech => (
							<span class="tech-tag">{tech}</span>
						))}
					</div>
				</div>
			</div>

			<div class="hero-cta">
				<a href="#work" class="btn btn-primary">
					<span>View My Work</span>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
				</a>
				<a href="#contact" class="btn">
					<span>Get In Touch</span>
				</a>
			</div>
		</div>

		<div class="scroll-indicator">
			<span>Scroll</span>
			<div class="scroll-line"></div>
		</div>
	</section>

	<!-- About Section -->
	<section id="about" class="section about">
		<div class="container">
			<header class="section-header">
				<span class="section-number">01</span>
				<h2>// About Me</h2>
			</header>

			<div class="about-content">
				<div class="about-text">
					<p class="about-intro">
						I'm a <span class="highlight">Senior Software Engineer</span> with over 12 years of experience building scalable web applications and leading engineering teams.
					</p>
					<p>
						Currently focused on creating exceptional digital experiences using modern technologies. I specialize in React, TypeScript, and Node.js, with a passion for clean code, performance optimization, and developer experience.
					</p>
					<p>
						When I'm not coding, you'll find me exploring new technologies, contributing to open source, or enjoying time with family and friends.
					</p>

					<div class="about-stats">
						<div class="stat">
							<span class="stat-number">12+</span>
							<span class="stat-label">Years Experience</span>
						</div>
						<div class="stat">
							<span class="stat-number">50+</span>
							<span class="stat-label">Projects Completed</span>
						</div>
						<div class="stat">
							<span class="stat-number">8</span>
							<span class="stat-label">Companies</span>
						</div>
					</div>
				</div>

				<div class="about-image">
					<div class="image-frame">
						<img
							src="/personal-site/assets/portrait.jpg"
							alt="Carlos Villanueva"
							width="400"
							height="500"
							loading="lazy"
						/>
						<div class="image-border"></div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Skills Section -->
	<section id="skills" class="section skills">
		<div class="container">
			<header class="section-header">
				<span class="section-number">02</span>
				<h2>// Skills & Expertise</h2>
			</header>

			<div class="skills-grid stagger">
				<div class="skill-card card">
					<div class="skill-icon">
						<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 6.1H3M21 12H3M21 18H3"/><circle cx="19" cy="6" r="2"/></svg>
					</div>
					<h3>Frontend Development</h3>
					<p>Building modern, responsive interfaces with React, TypeScript, and Next.js. Expert in state management, component architecture, and performance optimization.</p>
					<div class="skill-tags">
						<span>React</span>
						<span>TypeScript</span>
						<span>Next.js</span>
					</div>
				</div>

				<div class="skill-card card">
					<div class="skill-icon">
						<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
					</div>
					<h3>Backend Development</h3>
					<p>Creating robust APIs and microservices with Node.js, Express, and GraphQL. Experienced with databases, caching, and message queues.</p>
					<div class="skill-tags">
						<span>Node.js</span>
						<span>GraphQL</span>
						<span>PostgreSQL</span>
					</div>
				</div>

				<div class="skill-card card">
					<div class="skill-icon">
						<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
					</div>
					<h3>DevOps & Cloud</h3>
					<p>Setting up CI/CD pipelines, containerization with Docker, and cloud infrastructure on AWS. Familiar with Kubernetes and infrastructure as code.</p>
					<div class="skill-tags">
						<span>AWS</span>
						<span>Docker</span>
						<span>Kubernetes</span>
					</div>
				</div>

				<div class="skill-card card">
					<div class="skill-icon">
						<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
					</div>
					<h3>Team Leadership</h3>
					<p>Leading and mentoring development teams, conducting code reviews, and establishing best practices. Strong communication and collaboration skills.</p>
					<div class="skill-tags">
						<span>Agile</span>
						<span>Mentoring</span>
						<span>Code Review</span>
					</div>
				</div>
			</div>

			<div class="skills-bar-section">
				<h3>Proficiency Levels</h3>
				<div class="skills-bars">
					{skills.map(skill => (
						<div class="skill-bar-item">
							<div class="skill-bar-header">
								<span class="skill-bar-icon">{skill.icon}</span>
								<span class="skill-bar-name">{skill.name}</span>
								<span class="skill-bar-percent">{skill.level}%</span>
							</div>
							<div class="skill-bar-track">
								<div class="skill-bar-fill" style={`--level: ${skill.level}%`}></div>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- Work Section -->
	<section id="work" class="section work">
		<div class="container">
			<header class="section-header">
				<span class="section-number">03</span>
				<h2>// Selected Work</h2>
			</header>

			<div class="work-grid stagger">
				{projects.map((project, index) => (
					<a href={`/personal-site/work/${project.slug}`} class="work-card">
						<div class="work-card-image">
							<img
								src={project.data.img}
								alt={project.data.img_alt || project.data.title}
								loading="lazy"
							/>
							<div class="work-card-overlay">
								<span class="view-project">View Project</span>
							</div>
						</div>
						<div class="work-card-content">
							<span class="work-card-number">{String(index + 1).padStart(2, '0')}</span>
							<h3>{project.data.title}</h3>
							<p>{project.data.description}</p>
							<div class="work-card-tags">
								{project.data.tags.slice(0, 3).map(tag => (
									<span class="work-tag">{tag}</span>
								))}
							</div>
						</div>
					</a>
				))}
			</div>

			<div class="work-cta">
				<a href="/personal-site/work/" class="btn">
					<span>View All Projects</span>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</a>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="section contact">
		<div class="container">
			<header class="section-header">
				<span class="section-number">04</span>
				<h2>// Get In Touch</h2>
			</header>

			<div class="contact-content">
				<div class="contact-text">
					<p class="contact-intro">
						I'm always interested in hearing about new projects and opportunities. Whether you have a question or just want to say hi, feel free to reach out!
					</p>

					<div class="contact-terminal">
						<div class="terminal-window small">
							<div class="terminal-header">
								<span class="terminal-dot red"></span>
								<span class="terminal-dot yellow"></span>
								<span class="terminal-dot green"></span>
							</div>
							<div class="terminal-body">
								<p class="terminal-line">
									<span class="prompt">$</span>
									<span class="command">echo $EMAIL</span>
								</p>
								<a href="mailto:carlos.aaron.villanueva@gmail.com" class="contact-email">carlos.aaron.villanueva@gmail.com</a>
							</div>
						</div>
					</div>
				</div>

				<div class="contact-links">
					<a href="mailto:carlos.aaron.villanueva@gmail.com" class="contact-link-card card">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
						<span>Send Email</span>
					</a>
					<a href="https://www.linkedin.com/in/carlos-aar%C3%B3n-villanueva-b2270a32/" target="_blank" rel="noopener noreferrer" class="contact-link-card card">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						<span>LinkedIn</span>
					</a>
					<a href="https://github.com/cavr" target="_blank" rel="noopener noreferrer" class="contact-link-card card">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
						<span>GitHub</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<footer class="footer">
		<div class="container">
			<div class="footer-content">
				<p class="footer-text">
					<span class="terminal-text">Designed & Built by Carlos Villanueva</span>
				</p>
				<p class="footer-copyright">
					&copy; {new Date().getFullYear()} All rights reserved.
				</p>
			</div>
		</div>
	</footer>
</BaseLayout>

<style>
	/* ========================================
	   Navigation
	   ======================================== */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: var(--z-nav);
		background: rgba(10, 10, 15, 0.9);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border-color);
	}

	.nav-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1400px;
		margin: 0 auto;
		padding: var(--space-4) var(--space-6);
	}

	.nav-logo {
		font-family: var(--font-mono);
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--text-primary);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.logo-bracket {
		color: var(--accent-primary);
	}

	.logo-text {
		color: var(--text-primary);
	}

	.nav-links {
		display: none;
		list-style: none;
		gap: var(--space-8);
	}

	.nav-link {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.nav-link:hover {
		color: var(--accent-primary);
	}

	.nav-socials {
		display: none;
		gap: var(--space-4);
	}

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		color: var(--text-secondary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-sm);
		transition: all var(--transition-fast);
	}

	.social-link svg {
		width: 18px;
		height: 18px;
	}

	.social-link:hover {
		color: var(--accent-primary);
		border-color: var(--accent-primary);
		box-shadow: var(--glow-primary);
	}

	.mobile-menu-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		background: transparent;
		border: 1px solid var(--border-color);
		border-radius: var(--radius-sm);
		cursor: pointer;
	}

	.hamburger {
		position: relative;
		width: 20px;
		height: 2px;
		background: var(--text-primary);
	}

	.hamburger::before,
	.hamburger::after {
		content: '';
		position: absolute;
		width: 100%;
		height: 100%;
		background: var(--text-primary);
		left: 0;
	}

	.hamburger::before { top: -6px; }
	.hamburger::after { top: 6px; }

	@media (min-width: 768px) {
		.nav-links {
			display: flex;
		}

		.nav-socials {
			display: flex;
		}

		.mobile-menu-btn {
			display: none;
		}
	}

	/* ========================================
	   Hero Section
	   ======================================== */
	.hero {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		padding: var(--space-24) var(--space-6);
		position: relative;
	}

	.hero-content {
		max-width: 900px;
		width: 100%;
	}

	.terminal-window {
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-lg);
		overflow: hidden;
		animation: fade-in-up 0.8s ease-out;
	}

	.terminal-window.small {
		max-width: 500px;
	}

	.terminal-header {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-3) var(--space-4);
		background: var(--bg-tertiary);
		border-bottom: 1px solid var(--border-color);
	}

	.terminal-dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
	}

	.terminal-dot.red { background: #ff5f56; }
	.terminal-dot.yellow { background: #ffbd2e; }
	.terminal-dot.green { background: #27c93f; }

	.terminal-title {
		margin-left: var(--space-4);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-muted);
	}

	.terminal-body {
		padding: var(--space-6);
	}

	.terminal-line {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
