---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Blog | Carlos Villanueva" description="Thoughts on software engineering, backend systems, and the things I run into building production code.">
	<nav class="nav">
		<div class="nav-container">
			<a href="/personal-site/" class="nav-logo">
				<span class="logo-bracket">{</span>
				<span class="logo-text">CV</span>
				<span class="logo-bracket">}</span>
			</a>
			<a href="/personal-site/" class="back-link">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
				<span>Home</span>
			</a>
		</div>
	</nav>

	<main class="main">
		<div class="container">
			<header class="page-header">
				<p class="page-label">// blog</p>
				<h1 class="page-title">Writing</h1>
				<p class="page-description">Things I run into building production systems. Mostly backend, always practical.</p>
			</header>

			<ul class="posts-list">
				{posts.map(post => (
					<li>
						<a href={`/personal-site/blog/${post.slug}/`} class="post-card">
							<div class="post-meta">
								<span class="post-date">
									{new Date(post.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
								</span>
								<div class="post-tags">
									{post.data.tags.map(tag => (
										<span class="tag">{tag}</span>
									))}
								</div>
							</div>
							<h2 class="post-title">{post.data.title}</h2>
							<p class="post-description">{post.data.description}</p>
							<span class="read-more">
								Read post
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
							</span>
						</a>
					</li>
				))}
			</ul>
		</div>
	</main>

	<footer class="footer">
		<div class="container">
			<div class="footer-content">
				<p class="footer-text">
					<span class="terminal-text">Designed & Built by Carlos Villanueva</span>
				</p>
				<p class="footer-copyright">
					&copy; {new Date().getFullYear()} All rights reserved.
				</p>
			</div>
		</div>
	</footer>
</BaseLayout>

<style>
	.nav {
		position: sticky;
		top: 0;
		z-index: var(--z-nav);
		background: rgba(10, 10, 15, 0.9);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border-color);
	}

	.nav-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1400px;
		margin: 0 auto;
		padding: var(--space-4) var(--space-6);
	}

	.nav-logo {
		font-family: var(--font-mono);
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--text-primary);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.logo-bracket { color: var(--accent-primary); }

	.back-link {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.back-link:hover { color: var(--accent-primary); }

	.main {
		padding: var(--space-16) 0;
	}

	.page-header {
		max-width: 800px;
		margin-bottom: var(--space-16);
	}

	.page-label {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent-primary);
		margin-bottom: var(--space-2);
	}

	.page-title {
		font-size: clamp(2.5rem, 6vw, 4rem);
		line-height: 1.1;
		margin-bottom: var(--space-4);
	}

	.page-description {
		font-size: var(--text-xl);
		color: var(--text-secondary);
		line-height: 1.6;
	}

	.posts-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
		max-width: 800px;
	}

	.post-card {
		display: block;
		padding: var(--space-8);
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-lg);
		text-decoration: none;
		transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
	}

	.post-card:hover {
		border-color: var(--accent-primary);
		box-shadow: var(--glow-primary);
		transform: translateY(-2px);
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-3);
		margin-bottom: var(--space-4);
	}

	.post-date {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent-secondary);
		padding: var(--space-1) var(--space-3);
		background: rgba(0, 212, 255, 0.1);
		border: 1px solid rgba(0, 212, 255, 0.3);
		border-radius: var(--radius-sm);
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.tag {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent-primary);
		padding: var(--space-1) var(--space-3);
		background: rgba(0, 255, 136, 0.1);
		border: 1px solid rgba(0, 255, 136, 0.3);
		border-radius: var(--radius-sm);
	}

	.post-title {
		font-size: var(--text-2xl);
		line-height: 1.2;
		color: var(--text-primary);
		margin-bottom: var(--space-3);
	}

	.post-description {
		font-size: var(--text-base);
		color: var(--text-secondary);
		line-height: 1.7;
		margin-bottom: var(--space-6);
	}

	.read-more {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent-primary);
	}

	.footer {
		padding: var(--space-8) var(--space-6);
		border-top: 1px solid var(--border-color);
	}

	.footer-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-2);
		text-align: center;
	}

	.footer-text {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
	}

	.terminal-text::before {
		content: '> ';
		color: var(--accent-primary);
		opacity: 0.6;
	}

	.footer-copyright {
		font-size: var(--text-xs);
		color: var(--text-muted);
	}

	@media (min-width: 768px) {
		.footer-content {
			flex-direction: row;
			justify-content: space-between;
		}
	}
</style>
