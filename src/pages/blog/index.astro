---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.map((post, i) => ({
		...post,
		readingTime: Math.ceil(post.body.split(/\s+/).filter(Boolean).length / 200),
		coverIndex: i % 5, // cycles through 5 colour schemes
	}));

const featured = null;
const rest = posts;
---

<BaseLayout title="Blog | Carlos Villanueva" description="Thoughts on software engineering, backend systems, and the things I run into building production code.">
	<nav class="nav">
		<div class="nav-container">
			<a href="/personal-site/" class="nav-logo">
				<span class="logo-bracket">{</span>
				<span class="logo-text">CV</span>
				<span class="logo-bracket">}</span>
			</a>
			<div class="nav-right">
				<a href="/personal-site/" class="back-link">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
					<span>Home</span>
				</a>
				<a href="/personal-site/rss.xml" class="rss-link" aria-label="RSS feed" title="Subscribe via RSS">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1" fill="currentColor"/></svg>
				</a>
			</div>
		</div>
	</nav>

	<main class="main">
		<div class="container">
			<header class="page-header">
				<p class="page-label">// blog</p>
				<h1 class="page-title">Writing</h1>
				<p class="page-description">Things I run into building production systems. Mostly backend, always practical.</p>
			</header>

			<!-- Grid of posts -->
			<ul class="posts-grid">
				{rest.map(post => (
					<li>
						<a href={`/personal-site/blog/${post.slug}/`} class={`post-card cover-${post.coverIndex}`}>
							<div class="post-cover">
								<div class="cover-lines" aria-hidden="true">
									<span/><span/><span/><span/><span/><span/>
								</div>
								<span class="cover-tag">{post.data.tags[0]}</span>
							</div>
							<div class="post-body">
								<div class="post-meta">
									<span class="post-date">{new Date(post.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
									<span class="reading-time">
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
										{post.readingTime} min
									</span>
								</div>
								<h2 class="post-title">{post.data.title}</h2>
								<p class="post-description">{post.data.description}</p>
								<div class="post-footer">
									<div class="post-tags">
										{post.data.tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
									</div>
									<span class="read-more">
										Read
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
									</span>
								</div>
							</div>
						</a>
					</li>
				))}
			</ul>
		</div>
	</main>

	<footer class="footer">
		<div class="container">
			<div class="footer-content">
				<p class="footer-text">
					<span class="terminal-text">Designed & Built by Carlos Villanueva</span>
				</p>
				<p class="footer-copyright">
					&copy; {new Date().getFullYear()} All rights reserved.
				</p>
			</div>
		</div>
	</footer>
</BaseLayout>

<style>
	/* ── Nav ───────────────────────────────────────── */
	.nav {
		position: sticky;
		top: 0;
		z-index: var(--z-nav);
		background: rgba(10, 10, 15, 0.9);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border-color);
	}

	[data-theme="light"] .nav {
		background: rgba(247, 247, 249, 0.92);
	}

	.nav-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1400px;
		margin: 0 auto;
		padding: var(--space-4) var(--space-6);
	}

	.nav-logo {
		font-family: var(--font-mono);
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--text-primary);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.logo-bracket { color: var(--accent-primary); }

	.nav-right {
		display: flex;
		align-items: center;
		gap: var(--space-4);
	}

	.back-link {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.back-link:hover { color: var(--accent-primary); }

	.rss-link {
		display: flex;
		align-items: center;
		color: var(--text-muted);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.rss-link:hover { color: #ffaa00; }

	/* ── Page ──────────────────────────────────────── */
	.main {
		padding: var(--space-16) 0 var(--space-24);
	}

	.page-header {
		margin-bottom: var(--space-12);
	}

	.page-label {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent-primary);
		margin-bottom: var(--space-2);
	}

	.page-title {
		font-size: clamp(2.5rem, 6vw, 4rem);
		line-height: 1.1;
		margin-bottom: var(--space-4);
	}

	.page-description {
		font-size: var(--text-xl);
		color: var(--text-secondary);
		line-height: 1.6;
		max-width: 600px;
	}

	/* ── Cover colour schemes ──────────────────────── */
	/* Each scheme defines the cover gradient + line/tag colour */
	.cover-0 { --cover-a: #0a1a12; --cover-b: #0d2a1c; --cover-accent: #00ff88; }
	.cover-1 { --cover-a: #0a1520; --cover-b: #0d2030; --cover-accent: #00d4ff; }
	.cover-2 { --cover-a: #1a0a1a; --cover-b: #2a0d2a; --cover-accent: #ff00ff; }
	.cover-3 { --cover-a: #1a1200; --cover-b: #2a1e00; --cover-accent: #ffaa00; }
	.cover-4 { --cover-a: #0d0d1a; --cover-b: #16163a; --cover-accent: #8080ff; }

	[data-theme="light"] .cover-0 { --cover-a: #e8f5ee; --cover-b: #d0eeda; --cover-accent: #008040; }
	[data-theme="light"] .cover-1 { --cover-a: #e5f3fa; --cover-b: #c8e8f5; --cover-accent: #0077b6; }
	[data-theme="light"] .cover-2 { --cover-a: #f5e5f5; --cover-b: #eec8ee; --cover-accent: #8b00c8; }
	[data-theme="light"] .cover-3 { --cover-a: #fdf5e0; --cover-b: #f5e8b0; --cover-accent: #b05c00; }
	[data-theme="light"] .cover-4 { --cover-a: #eeeef9; --cover-b: #d8d8f0; --cover-accent: #4040c8; }

	/* ── Card ──────────────────────────────────────── */
	.post-card {
		display: flex;
		flex-direction: column;
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-lg);
		overflow: hidden;
		text-decoration: none;
		transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
		height: 100%;
	}

	.post-card:hover {
		border-color: var(--cover-accent, var(--accent-primary));
		box-shadow: 0 0 24px color-mix(in srgb, var(--cover-accent, var(--accent-primary)) 30%, transparent);
		transform: translateY(-4px);
	}

	/* ── Cover panel ───────────────────────────────── */
	.post-cover {
		position: relative;
		height: 180px;
		background: linear-gradient(135deg, var(--cover-a), var(--cover-b));
		overflow: hidden;
		display: flex;
		align-items: flex-end;
		padding: var(--space-4) var(--space-6);
		flex-shrink: 0;
	}

	/* Decorative code lines */
	.cover-lines {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 10px;
		padding: var(--space-6);
		opacity: 0.25;
	}

	.cover-lines span {
		display: block;
		height: 2px;
		border-radius: 1px;
		background: var(--cover-accent);
	}

	/* Vary line widths to look like real code */
	.cover-lines span:nth-child(1) { width: 65%; margin-left: 0; }
	.cover-lines span:nth-child(2) { width: 42%; margin-left: 5%; }
	.cover-lines span:nth-child(3) { width: 78%; margin-left: 5%; }
	.cover-lines span:nth-child(4) { width: 30%; margin-left: 10%; }
	.cover-lines span:nth-child(5) { width: 55%; margin-left: 5%; }
	.cover-lines span:nth-child(6) { width: 70%; margin-left: 0; }
	.cover-lines span:nth-child(7) { width: 35%; margin-left: 5%; }
	.cover-lines span:nth-child(8) { width: 50%; margin-left: 10%; }

	.post-card:hover .cover-lines {
		opacity: 0.4;
		transition: opacity var(--transition-base);
	}

	/* Tag badge on the cover */
	.cover-tag {
		position: relative;
		z-index: 1;
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: 600;
		color: var(--cover-accent);
		background: color-mix(in srgb, var(--cover-accent) 12%, transparent);
		border: 1px solid color-mix(in srgb, var(--cover-accent) 35%, transparent);
		padding: 3px var(--space-3);
		border-radius: 9999px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	/* ── Card body ─────────────────────────────────── */
	.post-body {
		padding: var(--space-6) var(--space-8);
		display: flex;
		flex-direction: column;
		flex: 1;
		gap: var(--space-3);
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-3);
	}

	.post-date {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
	}

	.reading-time {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
	}

	.post-title {
		font-size: var(--text-xl);
		line-height: 1.25;
		color: var(--text-primary);
		margin: 0;
		transition: color var(--transition-fast);
	}

	.post-card:hover .post-title {
		color: var(--cover-accent, var(--accent-primary));
	}

	.post-description {
		font-size: var(--text-sm);
		color: var(--text-secondary);
		line-height: 1.7;
		margin: 0;
		flex: 1;

		/* Clamp to 3 lines on grid cards */
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		margin-top: auto;
		padding-top: var(--space-4);
		border-top: 1px solid var(--border-color);
		flex-wrap: wrap;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.tag {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--cover-accent, var(--accent-primary));
		padding: 2px var(--space-2);
		background: color-mix(in srgb, var(--cover-accent, var(--accent-primary)) 10%, transparent);
		border: 1px solid color-mix(in srgb, var(--cover-accent, var(--accent-primary)) 30%, transparent);
		border-radius: var(--radius-sm);
	}

	.read-more {
		display: inline-flex;
		align-items: center;
		gap: var(--space-1);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
		white-space: nowrap;
		flex-shrink: 0;
		transition: color var(--transition-fast);
	}

	.post-card:hover .read-more {
		color: var(--cover-accent, var(--accent-primary));
	}

	/* ── Grid ──────────────────────────────────────── */
	.posts-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-6);
	}

	@media (min-width: 640px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1100px) {
		.posts-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.posts-grid li {
		display: flex;
	}

	/* ── Footer ────────────────────────────────────── */
	.footer {
		padding: var(--space-8) var(--space-6);
		border-top: 1px solid var(--border-color);
	}

	.footer-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-2);
		text-align: center;
	}

	.footer-text {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
	}

	.terminal-text::before {
		content: '> ';
		color: var(--accent-primary);
		opacity: 0.6;
	}

	.footer-copyright {
		font-size: var(--text-xs);
		color: var(--text-muted);
	}

	@media (min-width: 768px) {
		.footer-content {
			flex-direction: row;
			justify-content: space-between;
		}
	}
</style>
