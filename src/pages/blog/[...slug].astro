---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
	entry: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={`${entry.data.title} | Carlos Villanueva`} description={entry.data.description}>
	<nav class="nav">
		<div class="nav-container">
			<a href="/personal-site/" class="nav-logo">
				<span class="logo-bracket">{</span>
				<span class="logo-text">CV</span>
				<span class="logo-bracket">}</span>
			</a>
			<a href="/personal-site/blog/" class="back-link">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
				<span>All Posts</span>
			</a>
		</div>
	</nav>

	<main class="main">
		<article class="container">
			<header class="post-header">
				<div class="post-meta">
					<span class="post-date">{new Date(entry.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
					<div class="post-tags">
						{entry.data.tags.map(tag => (
							<span class="tag">{tag}</span>
						))}
					</div>
				</div>
				<h1 class="post-title">{entry.data.title}</h1>
				<p class="post-description">{entry.data.description}</p>
			</header>

			<div class="post-content">
				<Content />
			</div>

			<div class="post-nav">
				<a href="/personal-site/blog/" class="nav-btn">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
					<span>All Posts</span>
				</a>
				<a href="/personal-site/#contact" class="nav-btn primary">
					<span>Get In Touch</span>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</a>
			</div>
		</article>
	</main>

	<footer class="footer">
		<div class="container">
			<div class="footer-content">
				<p class="footer-text">
					<span class="terminal-text">Designed & Built by Carlos Villanueva</span>
				</p>
				<p class="footer-copyright">
					&copy; {new Date().getFullYear()} All rights reserved.
				</p>
			</div>
		</div>
	</footer>
</BaseLayout>

<style>
	.nav {
		position: sticky;
		top: 0;
		z-index: var(--z-nav);
		background: rgba(10, 10, 15, 0.9);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border-color);
	}

	.nav-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1400px;
		margin: 0 auto;
		padding: var(--space-4) var(--space-6);
	}

	.nav-logo {
		font-family: var(--font-mono);
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--text-primary);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.logo-bracket {
		color: var(--accent-primary);
	}

	.back-link {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.back-link:hover {
		color: var(--accent-primary);
	}

	.main {
		padding: var(--space-16) 0;
	}

	.post-header {
		max-width: 800px;
		margin-bottom: var(--space-12);
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-4);
		margin-bottom: var(--space-4);
	}

	.post-date {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent-secondary);
		padding: var(--space-1) var(--space-3);
		background: rgba(0, 212, 255, 0.1);
		border: 1px solid rgba(0, 212, 255, 0.3);
		border-radius: var(--radius-sm);
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.tag {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent-primary);
		padding: var(--space-1) var(--space-3);
		background: rgba(0, 255, 136, 0.1);
		border: 1px solid rgba(0, 255, 136, 0.3);
		border-radius: var(--radius-sm);
	}

	.post-title {
		font-size: clamp(2rem, 6vw, 3.5rem);
		line-height: 1.1;
		margin-bottom: var(--space-4);
	}

	.post-description {
		font-size: var(--text-xl);
		color: var(--text-secondary);
		line-height: 1.6;
	}

	.post-content {
		max-width: 800px;
		margin-bottom: var(--space-16);
	}

	.post-content :global(h1),
	.post-content :global(h2),
	.post-content :global(h3),
	.post-content :global(h4),
	.post-content :global(h5),
	.post-content :global(h6) {
		color: var(--text-primary);
		margin-top: var(--space-8);
		margin-bottom: var(--space-4);
	}

	.post-content :global(h2) {
		font-size: var(--text-2xl);
		padding-bottom: var(--space-2);
		border-bottom: 1px solid var(--border-color);
	}

	.post-content :global(h3) {
		font-size: var(--text-xl);
	}

	.post-content :global(p) {
		color: var(--text-secondary);
		line-height: 1.8;
		margin-bottom: var(--space-4);
	}

	.post-content :global(a) {
		color: var(--accent-primary);
		text-decoration: underline;
		text-underline-offset: 2px;
		transition: color var(--transition-fast);
	}

	.post-content :global(a:hover) {
		color: var(--accent-secondary);
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		color: var(--text-secondary);
		padding-left: var(--space-6);
		margin-bottom: var(--space-4);
	}

	.post-content :global(li) {
		margin-bottom: var(--space-2);
		line-height: 1.8;
	}

	.post-content :global(code) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		color: var(--accent-primary);
		background: var(--bg-secondary);
		padding: 0.2em 0.4em;
		border-radius: var(--radius-sm);
	}

	.post-content :global(pre) {
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		padding: var(--space-4);
		overflow-x: auto;
		margin-bottom: var(--space-6);
	}

	.post-content :global(pre code) {
		background: none;
		padding: 0;
		color: var(--text-primary);
	}

	.post-content :global(blockquote) {
		border-left: 3px solid var(--accent-primary);
		padding-left: var(--space-4);
		margin: var(--space-6) 0;
		font-style: italic;
		color: var(--text-secondary);
	}

	.post-content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-bottom: var(--space-6);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
	}

	.post-content :global(th) {
		text-align: left;
		padding: var(--space-2) var(--space-4);
		border-bottom: 1px solid var(--accent-primary);
		color: var(--accent-primary);
	}

	.post-content :global(td) {
		padding: var(--space-2) var(--space-4);
		border-bottom: 1px solid var(--border-color);
		color: var(--text-secondary);
	}

	.post-nav {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		padding-top: var(--space-8);
		border-top: 1px solid var(--border-color);
	}

	.nav-btn {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-3) var(--space-6);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		background: transparent;
		border: 1px solid var(--border-color);
		border-radius: var(--radius-sm);
		text-decoration: none;
		transition: all var(--transition-base);
	}

	.nav-btn:hover {
		color: var(--accent-primary);
		border-color: var(--accent-primary);
		box-shadow: var(--glow-primary);
	}

	.nav-btn.primary {
		background: var(--gradient-primary);
		border: none;
		color: var(--bg-primary);
	}

	.nav-btn.primary:hover {
		box-shadow: var(--glow-primary);
		transform: translateY(-2px);
		color: var(--bg-primary);
	}

	.footer {
		padding: var(--space-8) var(--space-6);
		border-top: 1px solid var(--border-color);
	}

	.footer-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-2);
		text-align: center;
	}

	.footer-text {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
	}

	.terminal-text::before {
		content: '> ';
		color: var(--accent-primary);
		opacity: 0.6;
	}

	.footer-copyright {
		font-size: var(--text-xs);
		color: var(--text-muted);
	}

	@media (min-width: 768px) {
		.footer-content {
			flex-direction: row;
			justify-content: space-between;
		}
	}
</style>
