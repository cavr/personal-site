---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
	entry: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

// Reading time
const wordCount = entry.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.ceil(wordCount / 200);

// Table of contents (h2 and h3 only)
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

// Prev / Next post
const allPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const currentIndex = allPosts.findIndex(p => p.slug === entry.slug);
const prevPost = allPosts[currentIndex + 1] ?? null; // older
const nextPost = allPosts[currentIndex - 1] ?? null; // newer
---

<BaseLayout
	title={`${entry.data.title} | Carlos Villanueva`}
	description={entry.data.description}
	ogType="article"
	ogTitle={entry.data.title}
>
	<nav class="nav">
		<div class="nav-container">
			<a href="/personal-site/" class="nav-logo">
				<span class="logo-bracket">{</span>
				<span class="logo-text">CV</span>
				<span class="logo-bracket">}</span>
			</a>
			<a href="/personal-site/blog/" class="back-link">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
				<span>All Posts</span>
			</a>
		</div>
	</nav>

	<!-- Reading progress bar -->
	<div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

	<main class="main">
		<div class="post-layout container">
			<article class="post-article">
				<header class="post-header">
					<div class="post-meta">
						<span class="post-date">{new Date(entry.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
						<span class="reading-time">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
							{readingTime} min read
						</span>
						<div class="post-tags">
							{entry.data.tags.map(tag => (
								<span class="tag">{tag}</span>
							))}
						</div>
					</div>
					<h1 class="post-title">{entry.data.title}</h1>
					<p class="post-description">{entry.data.description}</p>
				</header>

				{tocHeadings.length > 0 && (
					<details class="toc-mobile">
						<summary class="toc-summary">// Table of Contents</summary>
						<nav class="toc-nav">
							<ul class="toc-list">
								{tocHeadings.map(h => (
									<li class={`toc-item toc-depth-${h.depth}`}>
										<a href={`#${h.slug}`} class="toc-link">{h.text}</a>
									</li>
								))}
							</ul>
						</nav>
					</details>
				)}

				<div class="post-content">
					<Content />
				</div>

				<div class="post-nav">
					{prevPost ? (
						<a href={`/personal-site/blog/${prevPost.slug}/`} class="nav-btn nav-btn--prev">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
							<span class="nav-btn-label">
								<span class="nav-btn-hint">Older</span>
								<span class="nav-btn-title">{prevPost.data.title}</span>
							</span>
						</a>
					) : (
						<a href="/personal-site/blog/" class="nav-btn">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
							<span>All Posts</span>
						</a>
					)}
					{nextPost && (
						<a href={`/personal-site/blog/${nextPost.slug}/`} class="nav-btn nav-btn--next">
							<span class="nav-btn-label">
								<span class="nav-btn-hint">Newer</span>
								<span class="nav-btn-title">{nextPost.data.title}</span>
							</span>
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					)}
				</div>
			</article>

			{tocHeadings.length > 0 && (
				<aside class="post-toc-desktop">
					<div class="toc-sticky">
						<p class="toc-title">// Contents</p>
						<nav>
							<ul class="toc-list">
								{tocHeadings.map(h => (
									<li class={`toc-item toc-depth-${h.depth}`}>
										<a href={`#${h.slug}`} class="toc-link">{h.text}</a>
									</li>
								))}
							</ul>
						</nav>
					</div>
				</aside>
			)}
		</div>
	</main>

	<footer class="footer">
		<div class="container">
			<div class="footer-content">
				<p class="footer-text">
					<span class="terminal-text">Designed & Built by Carlos Villanueva</span>
				</p>
				<p class="footer-copyright">
					&copy; {new Date().getFullYear()} All rights reserved.
				</p>
			</div>
		</div>
	</footer>
</BaseLayout>

<style>
	.nav {
		position: sticky;
		top: 0;
		z-index: var(--z-nav);
		background: rgba(10, 10, 15, 0.9);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border-color);
	}

	[data-theme="light"] .nav {
		background: rgba(247, 247, 249, 0.92);
	}

	.nav-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1400px;
		margin: 0 auto;
		padding: var(--space-4) var(--space-6);
	}

	.nav-logo {
		font-family: var(--font-mono);
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--text-primary);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.logo-bracket {
		color: var(--accent-primary);
	}

	.back-link {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.back-link:hover {
		color: var(--accent-primary);
	}

	/* Reading progress bar */
	.reading-progress {
		position: fixed;
		top: 0;
		left: 0;
		width: 0%;
		height: 3px;
		background: var(--accent-primary);
		z-index: 9999;
		transition: width 0.1s linear;
		box-shadow: 0 0 8px var(--accent-primary);
	}

	.main {
		padding: var(--space-16) 0;
	}

	/* Two-column layout: article + TOC sidebar */
	.post-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-12);
		align-items: start;
	}

	@media (min-width: 1100px) {
		.post-layout {
			grid-template-columns: minmax(0, 800px) 220px;
		}
	}

	.post-article {
		min-width: 0;
	}

	/* Desktop TOC sidebar */
	.post-toc-desktop {
		display: none;
	}

	@media (min-width: 1100px) {
		.post-toc-desktop {
			display: block;
		}
	}

	.toc-sticky {
		position: sticky;
		top: calc(65px + var(--space-8));
	}

	.toc-title {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent-primary);
		margin-bottom: var(--space-4);
		opacity: 0.8;
	}

	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		border-left: 1px solid var(--border-color);
	}

	.toc-item {
		padding-left: var(--space-3);
	}

	.toc-item.toc-depth-3 {
		padding-left: var(--space-6);
	}

	.toc-link {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
		text-decoration: none;
		line-height: 1.5;
		display: block;
		padding: 2px 0;
		transition: color var(--transition-fast);
	}

	.toc-link:hover,
	.toc-link.active {
		color: var(--accent-primary);
	}

	/* Mobile TOC (details/summary) */
	.toc-mobile {
		margin-bottom: var(--space-8);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		overflow: hidden;
	}

	@media (min-width: 1100px) {
		.toc-mobile {
			display: none;
		}
	}

	.toc-summary {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent-primary);
		padding: var(--space-3) var(--space-4);
		cursor: pointer;
		list-style: none;
		background: var(--bg-secondary);
	}

	.toc-summary::-webkit-details-marker { display: none; }

	.toc-nav {
		padding: var(--space-3) var(--space-4);
		background: var(--bg-secondary);
		border-top: 1px solid var(--border-color);
	}

	.toc-mobile .toc-list {
		border-left: none;
		gap: var(--space-2);
	}

	.toc-mobile .toc-item {
		padding-left: 0;
	}

	.toc-mobile .toc-item.toc-depth-3 {
		padding-left: var(--space-4);
	}

	.toc-mobile .toc-link {
		font-size: var(--text-sm);
	}

	.post-header {
		max-width: 800px;
		margin-bottom: var(--space-12);
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-4);
		margin-bottom: var(--space-4);
	}

	.post-date {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent-secondary);
		padding: var(--space-1) var(--space-3);
		background: rgba(0, 212, 255, 0.1);
		border: 1px solid rgba(0, 212, 255, 0.3);
		border-radius: var(--radius-sm);
	}

	.reading-time {
		display: inline-flex;
		align-items: center;
		gap: var(--space-1);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-muted);
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.tag {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent-primary);
		padding: var(--space-1) var(--space-3);
		background: rgba(0, 255, 136, 0.1);
		border: 1px solid rgba(0, 255, 136, 0.3);
		border-radius: var(--radius-sm);
	}

	.post-title {
		font-size: clamp(2rem, 6vw, 3.5rem);
		line-height: 1.1;
		margin-bottom: var(--space-4);
	}

	.post-description {
		font-size: var(--text-xl);
		color: var(--text-secondary);
		line-height: 1.6;
	}

	.post-content {
		max-width: 800px;
		margin-bottom: var(--space-16);
	}

	/* Code block wrapper for copy button */
	.post-content :global(.code-block-wrapper) {
		position: relative;
	}

	.post-content :global(.copy-btn) {
		position: absolute;
		top: var(--space-2);
		right: var(--space-2);
		padding: 2px var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
		background: var(--bg-tertiary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-sm);
		cursor: pointer;
		transition: all var(--transition-fast);
		opacity: 0;
	}

	.post-content :global(.code-block-wrapper:hover .copy-btn) {
		opacity: 1;
	}

	.post-content :global(.copy-btn:hover) {
		color: var(--accent-primary);
		border-color: var(--accent-primary);
	}

	.post-content :global(.copy-btn.copied) {
		color: var(--accent-primary);
		opacity: 1;
	}

	.post-content :global(h1),
	.post-content :global(h2),
	.post-content :global(h3),
	.post-content :global(h4),
	.post-content :global(h5),
	.post-content :global(h6) {
		color: var(--text-primary);
		margin-top: var(--space-8);
		margin-bottom: var(--space-4);
	}

	.post-content :global(h2) {
		font-size: var(--text-2xl);
		padding-bottom: var(--space-2);
		border-bottom: 1px solid var(--border-color);
	}

	.post-content :global(h3) {
		font-size: var(--text-xl);
	}

	.post-content :global(p) {
		color: var(--text-secondary);
		line-height: 1.8;
		margin-bottom: var(--space-4);
	}

	.post-content :global(a) {
		color: var(--accent-primary);
		text-decoration: underline;
		text-underline-offset: 2px;
		transition: color var(--transition-fast);
	}

	.post-content :global(a:hover) {
		color: var(--accent-secondary);
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		color: var(--text-secondary);
		padding-left: var(--space-6);
		margin-bottom: var(--space-4);
	}

	.post-content :global(li) {
		margin-bottom: var(--space-2);
		line-height: 1.8;
	}

	.post-content :global(code) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		color: var(--accent-primary);
		background: var(--bg-secondary);
		padding: 0.2em 0.4em;
		border-radius: var(--radius-sm);
	}

	.post-content :global(pre) {
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		padding: var(--space-4);
		overflow-x: auto;
		margin-bottom: var(--space-6);
	}

	.post-content :global(pre code) {
		background: none;
		padding: 0;
		color: var(--text-primary);
	}

	.post-content :global(blockquote) {
		border-left: 3px solid var(--accent-primary);
		padding-left: var(--space-4);
		margin: var(--space-6) 0;
		font-style: italic;
		color: var(--text-secondary);
	}

	.post-content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-bottom: var(--space-6);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
	}

	.post-content :global(th) {
		text-align: left;
		padding: var(--space-2) var(--space-4);
		border-bottom: 1px solid var(--accent-primary);
		color: var(--accent-primary);
	}

	.post-content :global(td) {
		padding: var(--space-2) var(--space-4);
		border-bottom: 1px solid var(--border-color);
		color: var(--text-secondary);
	}

	/* Prev / Next nav */
	.post-nav {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		padding-top: var(--space-8);
		border-top: 1px solid var(--border-color);
		justify-content: space-between;
	}

	.nav-btn {
		display: inline-flex;
		align-items: center;
		gap: var(--space-3);
		padding: var(--space-4) var(--space-6);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		text-decoration: none;
		transition: all var(--transition-base);
		max-width: 280px;
		flex: 1;
	}

	.nav-btn:hover {
		color: var(--accent-primary);
		border-color: var(--accent-primary);
		box-shadow: var(--glow-primary);
	}

	.nav-btn--next {
		margin-left: auto;
		flex-direction: row-reverse;
		text-align: right;
	}

	.nav-btn-label {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.nav-btn-hint {
		font-size: var(--text-xs);
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.nav-btn-title {
		font-size: var(--text-sm);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.footer {
		padding: var(--space-8) var(--space-6);
		border-top: 1px solid var(--border-color);
	}

	.footer-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-2);
		text-align: center;
	}

	.footer-text {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
	}

	.terminal-text::before {
		content: '> ';
		color: var(--accent-primary);
		opacity: 0.6;
	}

	.footer-copyright {
		font-size: var(--text-xs);
		color: var(--text-muted);
	}

	@media (min-width: 768px) {
		.footer-content {
			flex-direction: row;
			justify-content: space-between;
		}
	}
</style>

<script>
	// Reading progress bar
	const progressBar = document.getElementById('reading-progress');
	if (progressBar) {
		window.addEventListener('scroll', () => {
			const article = document.querySelector('.post-article') as HTMLElement;
			if (!article) return;
			const articleTop = article.offsetTop;
			const articleHeight = article.offsetHeight;
			const scrolled = window.scrollY - articleTop;
			const pct = Math.min(100, Math.max(0, (scrolled / (articleHeight - window.innerHeight)) * 100));
			progressBar.style.width = `${pct}%`;
		}, { passive: true });
	}

	// Copy-to-clipboard buttons on code blocks
	document.querySelectorAll<HTMLElement>('.post-content pre').forEach(pre => {
		const wrapper = document.createElement('div');
		wrapper.className = 'code-block-wrapper';
		pre.parentNode!.insertBefore(wrapper, pre);
		wrapper.appendChild(pre);

		const btn = document.createElement('button');
		btn.className = 'copy-btn';
		btn.textContent = 'Copy';
		btn.setAttribute('aria-label', 'Copy code');
		wrapper.appendChild(btn);

		btn.addEventListener('click', async () => {
			const code = pre.querySelector('code')?.textContent ?? pre.textContent ?? '';
			try {
				await navigator.clipboard.writeText(code);
				btn.textContent = 'Copied!';
				btn.classList.add('copied');
				setTimeout(() => {
					btn.textContent = 'Copy';
					btn.classList.remove('copied');
				}, 2000);
			} catch {
				btn.textContent = 'Error';
				setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
			}
		});
	});

	// TOC active link highlight on scroll
	const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
	if (tocLinks.length > 0) {
		const headingEls = Array.from(tocLinks).map(link => {
			const id = link.getAttribute('href')?.slice(1);
			return id ? document.getElementById(id) : null;
		}).filter(Boolean) as HTMLElement[];

		const onScroll = () => {
			let active = headingEls[0];
			for (const el of headingEls) {
				if (el.getBoundingClientRect().top <= 120) active = el;
			}
			tocLinks.forEach(link => {
				link.classList.toggle('active', link.getAttribute('href') === `#${active?.id}`);
			});
		};
		window.addEventListener('scroll', onScroll, { passive: true });
		onScroll();
	}
</script>
