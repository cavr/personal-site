---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Matrix Rain | Carlos Villanueva" description="Full-screen Matrix digital rain canvas animation. Interactive — click to change speed, colour, and density.">

	<nav class="nav">
		<div class="nav-container">
			<a href="/personal-site/" class="nav-logo">
				<span class="logo-bracket">{</span>
				<span class="logo-text">CV</span>
				<span class="logo-bracket">}</span>
			</a>
			<a href="/personal-site/" class="back-link">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
				<span>Back to Home</span>
			</a>
		</div>
	</nav>

	<main class="main">
		<canvas id="matrix-canvas"></canvas>

		<div class="controls">
			<p class="controls-title">// matrix.rain</p>
			<div class="controls-grid">
				<div class="control-group">
					<label class="control-label" for="speed-range">Speed</label>
					<input type="range" id="speed-range" class="control-range" min="20" max="200" value="60" />
				</div>
				<div class="control-group">
					<label class="control-label" for="density-range">Density</label>
					<input type="range" id="density-range" class="control-range" min="8" max="24" value="14" />
				</div>
				<div class="control-group color-group">
					<label class="control-label">Color</label>
					<div class="color-swatches">
						<button class="swatch active" data-color="#00ff88" style="--c:#00ff88" title="Green"></button>
						<button class="swatch" data-color="#00d4ff" style="--c:#00d4ff" title="Cyan"></button>
						<button class="swatch" data-color="#ff00ff" style="--c:#ff00ff" title="Magenta"></button>
						<button class="swatch" data-color="#ffaa00" style="--c:#ffaa00" title="Amber"></button>
						<button class="swatch" data-color="#ffffff" style="--c:#ffffff" title="White"></button>
					</div>
				</div>
			</div>
		</div>
	</main>

</BaseLayout>

<style>
	/* Nav */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: var(--z-nav);
		background: rgba(0, 0, 0, 0.7);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(0, 255, 136, 0.15);
	}

	.nav-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1400px;
		margin: 0 auto;
		padding: var(--space-4) var(--space-6);
	}

	.nav-logo {
		font-family: var(--font-mono);
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--text-primary);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.logo-bracket { color: var(--accent-primary); }

	.back-link {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.back-link:hover { color: var(--accent-primary); }

	/* Full-page canvas */
	.main {
		position: relative;
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		background: #000;
	}

	#matrix-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	/* Controls overlay */
	.controls {
		position: fixed;
		bottom: var(--space-6);
		left: 50%;
		transform: translateX(-50%);
		background: rgba(0, 0, 0, 0.75);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(0, 255, 136, 0.2);
		border-radius: var(--radius-lg);
		padding: var(--space-4) var(--space-6);
		z-index: 10;
		min-width: 320px;
		max-width: 90vw;
	}

	.controls-title {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent-primary);
		opacity: 0.7;
		margin-bottom: var(--space-4);
	}

	.controls-grid {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-6);
		align-items: flex-end;
	}

	.control-group {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.control-label {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
	}

	.control-range {
		appearance: none;
		width: 120px;
		height: 4px;
		background: var(--bg-tertiary);
		border-radius: 2px;
		outline: none;
		cursor: pointer;
	}

	.control-range::-webkit-slider-thumb {
		appearance: none;
		width: 14px;
		height: 14px;
		border-radius: 50%;
		background: var(--accent-primary);
		cursor: pointer;
		box-shadow: 0 0 8px var(--accent-primary);
	}

	.color-swatches {
		display: flex;
		gap: var(--space-2);
	}

	.swatch {
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--c);
		border: 2px solid transparent;
		cursor: pointer;
		transition: border-color 0.15s ease, transform 0.15s ease;
	}

	.swatch:hover {
		transform: scale(1.2);
	}

	.swatch.active {
		border-color: #fff;
		box-shadow: 0 0 8px var(--c);
	}
</style>

<script>
	const canvas = document.getElementById('matrix-canvas') as HTMLCanvasElement;
	const ctx = canvas.getContext('2d')!;

	const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789ABCDEF<>{}[]|/\\';

	let color = '#00ff88';
	let interval = 60; // ms
	let colWidth = 14;

	let cols: number[] = [];
	let timerId: ReturnType<typeof setInterval>;

	function resize() {
		canvas.width = window.innerWidth;
		canvas.height = window.innerHeight;
		const count = Math.floor(canvas.width / colWidth);
		cols = Array.from({ length: count }, () => Math.floor(Math.random() * canvas.height / colWidth));
	}

	function hexToRgb(hex: string) {
		const r = parseInt(hex.slice(1, 3), 16);
		const g = parseInt(hex.slice(3, 5), 16);
		const b = parseInt(hex.slice(5, 7), 16);
		return `${r},${g},${b}`;
	}

	function drawFrame() {
		ctx.fillStyle = 'rgba(0,0,0,0.08)';
		ctx.fillRect(0, 0, canvas.width, canvas.height);

		const rgb = hexToRgb(color);
		cols.forEach((y, i) => {
			// Leading character brighter
			ctx.fillStyle = `rgba(${rgb},1)`;
			const char = chars[Math.floor(Math.random() * chars.length)];
			ctx.font = `${colWidth}px JetBrains Mono, monospace`;
			ctx.fillText(char, i * colWidth, y * colWidth);

			if (y * colWidth > canvas.height && Math.random() > 0.975) {
				cols[i] = 0;
			} else {
				cols[i]++;
			}
		});
	}

	function startAnimation() {
		clearInterval(timerId);
		timerId = setInterval(drawFrame, interval);
	}

	resize();
	window.addEventListener('resize', () => { resize(); });
	startAnimation();

	// Speed control
	const speedRange = document.getElementById('speed-range') as HTMLInputElement;
	speedRange.addEventListener('input', () => {
		// slider left = fast (low ms), right = slow (high ms). Invert.
		interval = 220 - parseInt(speedRange.value);
		startAnimation();
	});

	// Density (column width) control
	const densityRange = document.getElementById('density-range') as HTMLInputElement;
	densityRange.addEventListener('input', () => {
		colWidth = parseInt(densityRange.value);
		resize();
	});

	// Color swatches
	document.querySelectorAll<HTMLButtonElement>('.swatch').forEach(btn => {
		btn.addEventListener('click', () => {
			document.querySelectorAll('.swatch').forEach(s => s.classList.remove('active'));
			btn.classList.add('active');
			color = btn.dataset.color!;
		});
	});
</script>
