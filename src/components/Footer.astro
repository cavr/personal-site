---
import Icon from './Icon.astro';
const currentYear = () => new Date().getFullYear();
---

<footer>
	<div class="group">
		<p>
			Designed & Developed in Spain with <a href="https://astro.build/">Astro</a>
			<Icon icon="rocket-launch" size="1.2em" />
		</p>
		<p>&copy; {currentYear()} Carlos Villanueva</p>
	</div>
	<p class="socials">
		<a href="https://twitter.com/CarlosAaronVill"> Twitter</a>
		<a href="https://github.com/cavr"> GitHub</a>
	</p>
</footer>
<style>
	footer {
		display: flex;
		flex-direction: column;
		gap: 3rem;
		margin-top: auto;
		padding: 3rem 2rem 3rem;
		text-align: center;
		color: var(--gray-400);
		font-size: var(--text-sm);
		opacity: 0;
		animation: fade-in 0.5s ease-out 0.2s forwards;
	}

	footer a {
		position: relative;
		color: var(--gray-400);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	footer a::after {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 0;
		height: 1px;
		background: currentColor;
		transition: width 0.3s ease;
	}

	footer a:hover,
	footer a:focus {
		color: var(--gray-200);
	}

	footer a:hover::after,
	footer a:focus::after {
		width: 100%;
	}

	.group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.socials {
		display: flex;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.socials a {
		transition: color 0.2s ease, transform 0.2s ease;
	}

	.socials a:hover {
		transform: translateY(-2px);
	}

	@media (min-width: 50em) {
		footer {
			flex-direction: row;
			justify-content: space-between;
			padding: 2.5rem 5rem;
		}

		.group {
			flex-direction: row;
			gap: 1rem;
			flex-wrap: wrap;
		}

		.socials {
			justify-content: flex-end;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		footer {
			animation: none;
			opacity: 1;
		}
		footer a::after,
		.socials a {
			transition: none;
		}
		.socials a:hover {
			transform: none;
		}
	}
</style>
