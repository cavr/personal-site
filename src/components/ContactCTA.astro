---
import CallToAction from './CallToAction.astro';
import Icon from './Icon.astro';
---

<aside>
	<h2>
		Would you like to work together?
	</h2>
	<CallToAction href="mailto:carlos.aaron.villanueva@gmail.com">
		Send Me a Message
		<Icon icon="paper-plane-tilt" size="1.2em" />
	</CallToAction>
</aside>

<style>
	aside {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3rem;
		border-top: 1px solid var(--gray-800);
		border-bottom: 1px solid var(--gray-800);
		padding: 5rem 1.5rem;
		background-color: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
		opacity: 0;
		animation: fade-in 0.6s ease-out 0.1s forwards;
	}

	aside::before {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		width: 200%;
		height: 200%;
		transform: translate(-50%, -50%);
		background: radial-gradient(
			circle at center,
			var(--accent-overlay) 0%,
			transparent 50%
		);
		opacity: 0.3;
		pointer-events: none;
	}

	h2 {
		position: relative;
		font-size: var(--text-xl);
		text-align: center;
		max-width: 15ch;
	}

	@media (min-width: 50em) {
		aside {
			padding: 7.5rem;
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: space-between;
		}

		h2 {
			font-size: var(--text-3xl);
			text-align: left;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		aside {
			animation: none;
			opacity: 1;
		}
	}
</style>
